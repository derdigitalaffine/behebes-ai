  "htmlContent": "<!--BEHEBES_EMAIL_LAYOUT_START-->\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#ffffff;\">\n  <tr>\n    <td align=\"center\" style=\"padding:40px 16px;\">\n      <table width=\"500\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n        <tr>\n          <td style=\"padding:0 0 32px 0;\">\n            <p style=\"margin:0 0 2px 0;font-size:10px;color:#003762;letter-spacing:0.12em;text-transform:uppercase;font-family:'Segoe UI',Arial,sans-serif;\">Verbandsgemeindeverwaltung</p>\n            <p style=\"margin:0;font-size:11px;color:#8fa3b4;font-family:'Segoe UI',Arial,sans-serif;\">Otterbach-Otterberg</p>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:0 0 8px 0;\">\n            <p style=\"margin:0 0 6px 0;font-size:19px;font-weight:700;color:#003762;font-family:'Segoe UI',Candara,Arial,sans-serif;\">Information zu Ihrer Meldung</p>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:0;font-size:14px;color:#1c1c1c;line-height:1.75;font-family:'Segoe UI',Arial,sans-serif;\">\n<!--BEHEBES_EMAIL_LAYOUT_BODY_START-->\n<p style=\"margin-top:0;\">Guten Tag {citizenName},</p>\n    \n      <p>zu Ihrer Meldung <strong>{ticketId}</strong> gibt es eine neue Information.</p>\n      <div style=\"background:#f1f6fb;border:1px solid #dbe3f0;padding:14px;border-radius:10px;margin:16px 0;\">\n        <p style=\"margin:0 0 6px 0;\"><strong>Kategorie:</strong> {category}</p>\n        <p style=\"margin:0 0 6px 0;\"><strong>Ort:</strong> {location}</p>\n        <p style=\"margin:0;\"><strong>Beschreibung:</strong> {description}</p>\n      </div>\n      <p>{customMessage}</p>\n    \n    <div style=\"margin:18px 0 16px 0;\"><a href=\"{validationLink}\" style=\"display:inline-block;background:#31932e;color:#ffffff;text-decoration:none;padding:10px 16px;border-radius:8px;font-weight:700;margin-right:8px;\">Meldung bestätigen</a><a href=\"{statusLink}\" style=\"display:inline-block;background:#003762;color:#ffffff;text-decoration:none;padding:10px 16px;border-radius:8px;font-weight:700;\">Status ansehen</a></div>\n<!--BEHEBES_EMAIL_LAYOUT_BODY_END-->\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>\n<!--BEHEBES_EMAIL_LAYOUT_END-->",
  "textContent": "Guten Tag {citizenName},\n\nzu Ihrer Meldung {ticketId} gibt es eine neue Information.\nKategorie: {category}\nOrt: {location}\nBeschreibung: {description}\n\n{customMessage}\n\nBestätigen: {validationLink}\nStatus: {statusLink}",
