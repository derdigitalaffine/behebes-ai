{
  "id": "status-change",
  "subject": "Status-Update zu Ihrer Meldung ({ticketId})",
  "htmlContent": "<!--BEHEBES_EMAIL_LAYOUT_START-->\n<table width=\"100%\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"background:#ffffff;\">\n  <tr>\n    <td align=\"center\" style=\"padding:40px 16px;\">\n      <table width=\"500\" cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n        <tr>\n          <td style=\"padding:0 0 32px 0;\">\n            <p style=\"margin:0 0 2px 0;font-size:10px;color:#003762;letter-spacing:0.12em;text-transform:uppercase;font-family:'Segoe UI',Arial,sans-serif;\">Verbandsgemeindeverwaltung</p>\n            <p style=\"margin:0;font-size:11px;color:#8fa3b4;font-family:'Segoe UI',Arial,sans-serif;\">Otterbach-Otterberg</p>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:0 0 8px 0;\">\n            <p style=\"margin:0 0 6px 0;font-size:19px;font-weight:700;color:#003762;font-family:'Segoe UI',Candara,Arial,sans-serif;\">Status-Update zu Ihrer Meldung</p>\n          </td>\n        </tr>\n        <tr>\n          <td style=\"padding:0;font-size:14px;color:#1c1c1c;line-height:1.75;font-family:'Segoe UI',Arial,sans-serif;\">\n<!--BEHEBES_EMAIL_LAYOUT_BODY_START-->\n<p style=\"margin-top:0;\">Guten Tag {citizenName},</p>\n    <p>der Bearbeitungsstand Ihres Tickets <strong>{ticketId}</strong> wurde aktualisiert.</p>\n    <div style=\"background:#f1f6fb;border:1px solid #dbe3f0;padding:14px;border-radius:10px;margin:16px 0;\">\n      <p style=\"margin:0 0 6px 0;\"><strong>Vorher:</strong> {oldStatus}</p>\n      <p style=\"margin:0 0 6px 0;\"><strong>Neu:</strong> {newStatus}</p>\n      <p style=\"margin:0;\">{statusMessage}</p>\n    </div>\n    <p style=\"margin:14px 0 0 0;\"><a href=\"{statusLink}\" style=\"display:inline-block;background:#003762;color:#ffffff;text-decoration:none;padding:11px 18px;border-radius:8px;font-weight:700;\">Bearbeitungsstand ansehen</a></p>\n    <p style=\"margin-top:16px;\">Wenn Sie keine weiteren automatischen E-Mails wünschen, können Sie diese hier abbestellen:</p>\n    <p style=\"margin:14px 0 0 0;\"><a href=\"{unsubscribeLink}\" style=\"display:inline-block;background:#6b7280;color:#ffffff;text-decoration:none;padding:11px 18px;border-radius:8px;font-weight:700;\">Automatische Benachrichtigungen abbestellen</a></p>\n    <div style=\"margin-top:16px;padding:10px 12px;border-radius:10px;background:#f1f6fb;border:1px solid #dbe3f0;color:#35556f;font-size:13px;line-height:1.5;\">Direktlink zur Statusseite: <span style=\"word-break:break-all;\">{statusLink}</span><br/>Abmelden: <span style=\"word-break:break-all;\">{unsubscribeLink}</span></div>\n<!--BEHEBES_EMAIL_LAYOUT_BODY_END-->\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>\n<!--BEHEBES_EMAIL_LAYOUT_END-->",
  "textContent": "Guten Tag {citizenName},\n\nder Bearbeitungsstand Ihres Tickets {ticketId} wurde aktualisiert.\nVorher: {oldStatus}\nNeu: {newStatus}\nHinweis: {statusMessage}\n\nStatusseite: {statusLink}\nAbbestellen: {unsubscribeLink}",
  "updatedAt": "2026-02-25T10:18:45.643Z",
  "createdAt": "2026-02-16T15:47:03.856Z"
}
