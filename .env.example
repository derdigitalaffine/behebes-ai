# ============================================
# Backend Configuration
# ============================================

# Node Environment
NODE_ENV=development
EXPRESS_PORT=3001

# Database
# DATABASE_CLIENT=sqlite|mysql
DATABASE_CLIENT=sqlite
DATABASE_PATH=./data/oi_app.db
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=change-root-password
MYSQL_USER=behebes
MYSQL_PASSWORD=behebes
MYSQL_DATABASE=behebes_ai
MYSQL_CONNECT_TIMEOUT_MS=10000
MYSQL_CONNECTION_RETRIES=30
MYSQL_CONNECTION_RETRY_DELAY_MS=2000
MYSQL_MIGRATE_FROM_SQLITE=true
MYSQL_MIGRATION_SQLITE_PATH=./data/oi_app.db

# JWT Authentication
JWT_SECRET=dev-secret-key-change-in-production
JWT_EXPIRY=24h
EXPRESS_TRUST_PROXY=1
FRONTEND_URL=https://www.behebes.de
ADMIN_URL=https://www.behebes.de/admin
CORS_ALLOWED_ORIGINS=https://www.behebes.de,https://behebes.de

# API Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1500
AUTH_RATE_LIMIT_WINDOW_MS=600000
AUTH_RATE_LIMIT_MAX=30

# ============================================
# AI Provider Configuration (Choose: openai or askcodi)
# ============================================

# AI Provider Selection: 'openai' or 'askcodi' (default: openai)
AI_PROVIDER=askcodi
AI_MODEL=gpt-4o

# OpenAI Provider (Option 1: Direct OpenAI API via OAuth)
OPENAI_CLIENT_ID=your-client-id-here
OPENAI_CLIENT_SECRET=your-client-secret-here
OPENAI_REDIRECT_URI=https://www.behebes.de/api/auth/openai/callback

# AskCodi Provider (Option 2: Multi-model LLM Gateway - OpenAI compatible)
# Get API key from: https://www.askcodi.com
# Supports GPT-4o, GPT-4, Claude, Gemini, Llama, Mistral, custom models
ASKCODI_API_KEY=your-askcodi-api-key
ASKCODI_BASE_URL=https://api.askcodi.com/v1

# ============================================
# Separate Image AI (OpenAI, independent from AI_PROVIDER)
# ============================================

# Enable standalone image-to-text analysis pipeline
IMAGE_AI_ENABLED=false
# Vision-capable model, e.g. gpt-4o-mini
IMAGE_AI_MODEL=gpt-4o-mini
# Dedicated API key for image analysis (separate from other AI settings)
IMAGE_AI_API_KEY=
# OpenAI-compatible base URL
IMAGE_AI_BASE_URL=https://api.openai.com/v1
# Detail level: auto | low | high
IMAGE_AI_DETAIL=auto
# Token + temperature controls for image descriptions
IMAGE_AI_MAX_TOKENS=500
IMAGE_AI_TEMPERATURE=0.2

# ============================================
# SMTP Configuration (Email Notifications)
# ============================================

SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=OI App Bürgermeldungen

# IMAP Inbox Sync (incoming replies -> ticket attachments)
IMAP_ENABLED=false
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=your-email@example.com
IMAP_PASSWORD=your-password
IMAP_MAILBOX=INBOX
IMAP_SYNC_LIMIT=80
IMAP_SYNC_INTERVAL_MINUTES=2

# ============================================
# XMPP Teamchat (ejabberd)
# ============================================

XMPP_ENABLED=true
XMPP_DOMAIN=localhost
XMPP_MUC_SERVICE=conference.localhost
XMPP_WEBSOCKET_URL=/xmpp-websocket
XMPP_API_URL=http://xmpp:5280/api
XMPP_API_USER=xmppadmin@localhost
XMPP_API_PASSWORD=xmppadmin-change-me
XMPP_EMAIL_NOTIFICATIONS_DEFAULT=true
# WebRTC STUN/TURN for voice/video calls (comma separated)
XMPP_RTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun.cloudflare.com:3478
XMPP_RTC_TURN_URLS=turn:ks1.troester.nl:3478?transport=udp,turn:ks1.troester.nl:3478?transport=tcp
XMPP_RTC_TURN_USERNAME=behebes_turn
XMPP_RTC_TURN_CREDENTIAL=change-me

# ============================================
# PWA Web Push (optional, recommended for production)
# ============================================
# Generate keys once:
# npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:noreply@example.com

# ============================================
# RedMine Integration (optional)
# ============================================

REDMINE_API_URL=https://redmine.example.com
REDMINE_API_KEY=your-redmine-api-key

# ============================================
# Frontend Configuration
# ============================================

VITE_API_URL=${VITE_API_URL}
VITE_NOMINATIM_API=https://nominatim.openstreetmap.org

# ============================================
# Admin Panel Configuration
# ============================================

VITE_ADMIN_API_URL=${VITE_API_URL}

# ============================================
# Feature Flags
# ============================================

ENABLE_LEARNING_MODE=true
AUTO_MODE_AFTER_N_FEEDBACKS=10
